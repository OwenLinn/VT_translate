{
  "name": "yt-live-translator-electron-overlay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Phase 2 Electron Liquid Glass overlay prototype for YouTube Live Translator.",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:mock": "cross-env OVERLAY_MODE=mock electron-vite dev",
    "dev:tuning": "cross-env OVERLAY_MODE=tuning electron-vite dev",
    "dev:live": "cross-env OVERLAY_MODE=mock OVERLAY_BRIDGE_MODE=live OVERLAY_BRIDGE_URL=ws://127.0.0.1:8765 electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "framer-motion": "^11.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.21.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-vite": "^2.3.0",
    "eslint": "^9.18.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^5.4.0"
  }
}
